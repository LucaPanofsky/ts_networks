{
  "name": "ts_networks",
  "version": "1.0.0",
  "description": "Propagation networks implementation in TypeScript",
  "type": "module",
  "main": "dist/index.js",
  "author": "Luca Panofsky",
  "license": "ISC",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "pretest": "npm run typecheck",
    "test": "jest && npm run test:esm",
    "test:esm": "ESM_TESTS=1 NODE_OPTIONS=--experimental-vm-modules jest",
    "pretest:all": "npm run typecheck",
    "test:all": "TEST_ALL=1 jest && npm run test:esm",
    "mcp": "npx tsx scripts/mcp.ts",
    "run-artifact": "node dist/operations/run-artifact.js",
    "run-tsn": "node dist/operations/run-source.js",
    "analyze": "jest --coverage --collectCoverageFrom='src/**/*.ts' --coverageReporters=json && npx tsx repo_workspace/analysis/report.ts",
    "analyze:quick": "npx tsx repo_workspace/analysis/report.ts"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tsn/runtime": "file:packages/tsn-runtime",
    "ohm-js": "^17.5.0",
    "unpdf": "^1.6.2"
  }
}
