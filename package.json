{
  "name": "ts_networks",
  "version": "1.0.0",
  "description": "Propagation networks implementation in TypeScript",
  "type": "module",
  "main": "dist/index.js",
  "author": "Luca Panofsky",
  "license": "ISC",
  "scripts": {
    "generate": "lezer-generator src/data-network/grammar.grammar --output src/data-network/parser.js",
    "build": "npm run generate && tsc && sed 's|from \"./prompt-tokenizer\"|from \"./prompt-tokenizer.js\"|' src/data-network/parser.js > dist/data-network/parser.js && cp src/data-network/parser.terms.js dist/data-network/parser.terms.js",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "pretest": "npm run typecheck",
    "test": "npm run generate && jest && npm run test:esm",
    "test:esm": "ESM_TESTS=1 NODE_OPTIONS=--experimental-vm-modules jest",
    "pretest:all": "npm run typecheck",
    "test:all": "npm run generate && TEST_ALL=1 jest && npm run test:esm",
    "mcp": "npx tsx scripts/mcp.ts",
    "analyze": "jest --coverage --collectCoverageFrom='src/**/*.ts' --coverageReporters=json && npx tsx repo_workspace/analysis/report.ts",
    "analyze:quick": "npx tsx repo_workspace/analysis/report.ts"
  },
  "devDependencies": {
    "@lezer/generator": "^1.8.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@lezer/common": "^1.5.2",
    "@lezer/lr": "^1.4.10",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ohm-js": "^17.5.0",
    "unpdf": "^1.6.2"
  }
}
