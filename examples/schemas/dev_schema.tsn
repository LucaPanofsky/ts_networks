defpredicate PositiveNumber?
  signature: from [Number?(n)] to Boolean?;
  expression
    n > 0;
end

defrecord Measurement
  value: PositiveNumber?;
  label: String?;
end

defrecord Source
  url: String?;
  confidence: PositiveNumber?;
end

defrecord AnnotatedMeasurement
  measurement: Measurement?;
  source: Source?;
  notes: String?;
end
