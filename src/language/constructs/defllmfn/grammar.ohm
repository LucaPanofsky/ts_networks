// Canonical, readable copy of the defllmfn SHELL grammar. Kept in sync by hand with the
// GRAMMAR_SOURCE string in parse.ts (the live copy; .ohm files are not importable under
// NodeNext/jest).
//
// The shell parses keyword, the fn-style signature, an optional `with:` config block, one or
// more triple-quoted prompt clauses, and `end`. `system`/`user` label the prompt channels; a
// bare (unlabelled) block is back-compat shorthand for the user prompt. Prompts are opaque
// text captured verbatim (rendered at RUN time by the same engine as defllmfn / interpolate).
//
//   defllmfn analyzeDocument
//     signature: from [String?(text)] to DocumentAnalysis?;
//     with: model = 'claude-opus-4-7';
//     system """You are an analyst.""";
//     user """Analyze: {{text}}""";
//   end

Llmfn {
  Main = "defllmfn" ident Signature With? Clause+ "end"
  Signature = "signature" ":" "from" Params? "to" TypeRef ";"
  Params = "[" ListOf<Param, ","> "]"
  Param = ident "(" ident ")"
  TypeRef = "[" ident "]"  -- vec
          | ident          -- scalar
  With = "with" ":" ListOf<ConfigPair, ","> ";"
  ConfigPair = ident "=" ConfigVal
  ConfigVal = string   -- str
            | number   -- num
            | ident    -- word
  Clause = "system" tripleString ";"  -- system
         | "user" tripleString ";"    -- user
         | tripleString ";"           -- bare
  string = "'" (~"'" any)* "'"
  number = "-"? digit+ ("." digit+)?
  tripleString = "\"\"\"" (~"\"\"\"" any)* "\"\"\""
  ident = letter identChar*
  identChar = alnum | "?" | "_"
}
