# Using a .env file is OPTIONAL — `docker compose` works with these exported in your shell.
# If you do want a file: cp .env.example .env, then fill in values. .env is gitignored.

# Your Anthropic API key. Passed into the container at runtime, never baked into the image.
# Prefer exporting it in your shell (export ANTHROPIC_API_KEY=...) so the secret never lands
# in a file; put it here only if you accept it sitting on disk. Get one at
# https://console.anthropic.com/.
ANTHROPIC_API_KEY=

# Host port for the chat UI. The container always listens on 8787 internally; this only
# changes the host-side port. Default: 8787 → http://localhost:8787
TSN_AGENT_PORT=8787

# Host directory bind-mounted at /workspace (the file channel + persistence). Relative paths
# are resolved from this docker/ directory. Default: ../tsn-work (i.e. <repo>/tsn-work).
TSN_AGENT_WORKDIR=../tsn-work

# Image tag/name to build and run. Default: tsn-agent
TSN_AGENT_IMAGE=tsn-agent
